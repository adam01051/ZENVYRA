<%- include('includes/header') %>

  <link rel="stylesheet" type="text/css" href="/css/products.css" />

  <body>
    <div class="products-container">
      <%- include('includes/navbar') %>

        <div class="restaurant-menu-frame">
          <div class="board">
            <div class="products-table">
              <span class="new-product-txt" style="margin-bottom: 30px">
                Products
              </span>
              <table class="table table-bordered table-hover">
                <thead class="thead-light">
                  <tr class="thead-light">
                    <th scope="col">T/r</th>
                    <th scope="col">Product Name</th>
                    <th scope="col">Product Type</th>
                    <th scope="col">Product Price</th>
                    <th scope="col">Product Left Count</th>
                    <th scope="col">Status</th>
                  </tr>
                </thead>
                <!--  LOOP PRODUCTS: START  -->
                <%products.map(function (value, key) {%>



                  <tbody style="background: white">
                    <td>
                      <%= key+1%>
                    </td>
                    <td>
                      <%= value.productName %>
                    </td>
                    <td>
                      <%= value.productCollection %>
                    </td>

                    <td>
                      <%= value.productPrice %>
                    </td>
                    <td>
                      <%value.variants.map(function (value1, key1) {%>
                    <div>
                      <%= value1.size%> : <%=  value1.stock%>
                    </div>


                    <% }) %>
                      </td>
                      <td>


                        <select class="spec-select new-product-status" id="<%= value._id %>">
                          <option value="PAUSE" <%=value.productStatus==='PAUSE' ?'selected': '' %>>PAUSE</option>
                          <option value="PROCESS" <%=value.productStatus==='PROCESS' ?'selected': '' %>>PROCESS</option>
                          <option value="DELETE" <%=value.productStatus==='DELETE' ?'selected': '' %>>DELETE</option>
                        </select>
                      </td>
                  </tbody>
                  <% }) %>
                    <!--  LOOP PRODUCTS: END  -->
              </table>
              <div class="long-input" style="align-items: flex-end; margin-bottom: 25px">
                <button class="btn btn-primary" id="process-btn">
                  New Product
                </button>
              </div>
            </div>
            <form onsubmit=" return validateForm()" action="/admin/product/create" method="POST"
              class="product-container" enctype="multipart/form-data">
              <div class="long-input" style="display: flex; align-items: center">
                <span class="new-product-txt">NEW PRODUCT DETAIL</span>
              </div>
              <div class="login-input-frame">
                <div class="long-input">
                  <label>Product Name</label>
                  <input type="text" placeholder="Name" name="productName" class="product-name" />
                </div>
                <input name="productStatus" value="PAUSE" class="product-status" hidden />
              </div>
              <div class="half-input-frame">
                <div class="half-input">
                  <label>Product Price</label>
                  <input type="number" placeholder="Price" name="productPrice" class="product-price" />
                </div>

              </div>
              <div class="half-input-frame">
                <div class="half-input half-sec">
                  <label style="width:20em;">Product Type</label>
                  <select class="product-collection" name="productCollection">
                    <option value="TSHIRT" selected>TSHIRT</option>
                    <option value="HOODIE">HOODIE</option>
                    <option value="JEANS">JEANS</option>
                    <option value="JACKET">JACKET</option>
                    <option value="SHOES">SHOES</option>
                  </select>
                </div>


                <div class="checkbox">

                  <div class="half-input">
                    <label>
                      <input type="checkbox" name="sizes" value="S" checked />
                      S
                    </label>
                    <input type="number" name="stockS" placeholder="Stock" />
                  </div>

                  <div class="half-input">
                    <label>
                      <input type="checkbox" name="sizes" value="M" />
                      M
                    </label>
                    <input type="number" name="stockM" placeholder="Stock" />
                  </div>

                </div>

                <div class="half-input-frame">

                  <div class="half-input">
                    <label>
                      <input type="checkbox" name="sizes" value="L" />
                      L
                    </label>
                    <input type="number" name="stockL" placeholder="Stock" />
                  </div>

                  <div class="half-input">
                    <label>
                      <input type="checkbox" name="sizes" value="XL" />
                      XL
                    </label>
                    <input type="number" name="stockXL" placeholder="Stock" />
                  </div>

                </div>

                <div class="half-input-frame">

                  <div class="half-input">
                    <label>
                      <input type="checkbox" name="sizes" value="XXL" />
                      XXL
                    </label>
                    <input type="number" name="stockXXL" placeholder="Stock" />
                  </div>

                </div>


              </div>
              <div class="long-input">
                <label>Product Description</label>
                <textarea name="productDesc" class="product-desc"></textarea>
              </div>

              <div class="img-frame">
                <label>Product Images</label>
                <div class="media-frame">
                  <div class="upload-img-box">
                    <img src="/img/upload.svg" class="1" id="image-section-1" />
                    <input type="file" id="file" name="productImages" class="image-one" required
                      onchange="previewFileHandler(this,1)" />
                  </div>
                  <div class="upload-img-box">
                    <img src="/img/upload.svg" class="2" id="image-section-2" />
                    <input type="file" id="file" name="productImages" class="image-two"
                      onchange="previewFileHandler(this,2)" />
                  </div>
                  <div class="upload-img-box">
                    <img src="/img/upload.svg" class="3" id="image-section-3" />
                    <input type="file" id="file" name="productImages" class="image-three"
                      onchange="previewFileHandler(this,3)" />
                  </div>
                

                </div>
              </div>

              <div class="operation-buttons">

                <button class="btn btn-danger" id="cancel-btn">Cancel</button>
                <button type="submit" class="btn btn-primary" id="create-btn">
                  Create
                </button>
              </div>
            </form>
          </div>
        </div>
    </div>

    <script type="text/javascript" src="/js/products.js"></script>
  </body>

  <%- include('includes/footer') %>
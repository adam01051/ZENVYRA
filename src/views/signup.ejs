<%- include('includes/header') %>

<link rel="stylesheet" type="text/css" href="/css/signup.css" />

<body>
	<%- include('includes/navbar') %>

	<div class="main-container">
		<div class="container-items1">
			<div class="signup-container">
				<form
					onsubmit="return validateSignupForm();"
					action="/admin/signup"
					method="POST"
					enctype="multipart/form-data"
				>
					<div class="signup-frame" style="width: 650px">
						<div class="signup-top">
							<span>Signup into your account</span>
						</div>

						<div
							class="sign-input-frame"
							style="justify-content: space-between"
						>
							<div class="sign-up-frame">
								<label>Store *</label>
								<input
									type="text"
									name="memberNick"
									class="member-nick"
									placeholder="Username"
									value=""
								/>
							</div>
							<div class="sign-up-frame">
								<label>Phone *</label>
								<input
									type="text"
									name="memberPhone"
									class="member-phone"
									placeholder="Phone"
									value=""
								/>
							</div>
						</div>
						<div
							class="sign-input-frame"
							style="justify-content: space-between"
						>
							<div class="sign-up-frame">
								<label>Password *</label>
								<input
									type="password"
									name="memberPassword"
									class="member-password"
									placeholder="Password"
									value=""
								/>
							</div>
							<div class="sign-up-frame">
								<label>Repeat password *</label>
								<input
									type="password"
									name="confirmPassword"
									class="confirm-password"
									placeholder="Repeat password"
									value=""
								/>
							</div>
						</div>

						<div class="signup-input-frame">
							<div class="media-frame">
								<img class="upload-img-frame" src="/img/default.jpeg" />
								<div class="upload-container">
									<span class="media-text">Product image</span>
									<div
										class="file-box bs3-primary preview-image"
										style="margin-top: 25px; display: flex"
									>
										<input
											class="upload-name"
											value="Choose image"
											disabled="disabled"
										/>
										<label for="input-file" class="file-input-label"
											>Upload Image</label
										>
										<input
											type="file"
											id="input-file"
											class="upload-hidden form-control-file member-image"
											name="memberImage"
										/>
									</div>
									<p class="thumbnail-desc">
										Please upload restaurant image.<br />
										Attention only:.jpg, .jpeg, or .png. <br />
										formats allowed!
									</p>
								</div>
							</div>
						</div>

						<input name="memberType" value="RESTAURANT" hidden />

						<button class="signup-btn btn" name="signup" type="submit">
							Signup
						</button>
            	<p class="quest-label">
								Already signed up?
								<a href="/admin/login" style="color: #494747; font-size: 18px;">Login</a>
							</p>
					</div>
          
				</form>
			</div>
		</div>
		<div class="container-items2"><%- include('includes/animation') %></div>
	</div>

	<script type="text/javascript" src="/js/signup.js"></script>
</body>

<%- include('includes/footer') %>

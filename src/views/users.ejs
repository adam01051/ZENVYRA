<%- include('includes/header') %>

<link rel="stylesheet" type="text/css" href="/css/users.css" />

<body>
  <div class="users-container">

    <%- include('includes/navbar') %>

    <div class="users-frame">
      <div class="board">

        <div class="user-table">

          <span class="header-name" style="margin-bottom: 30px">
            All Users List
          </span>

          <table class="table table-hover table-sm">

            <thead class="thead-light">
              <tr class="thead-light">
                <th scope="col">No</th>
                <th scope="col">Name</th>
                <th scope="col">Phone</th>
                <th scope="col">Status</th>
              </tr>
            </thead>

            <tbody style="background: white">

              <% users.map(function(value, index) { %>

                <tr>

                  <td>
                    <%= index + 1 %>
                  </td>

                  <td>
                    <%= value.memberNick %>
                  </td>

                  <td>
                    <%= value.memberPhone %>
                  </td>

                  <td style="width: 13%">

                    <select
                      class="spec-select member-status"
                      id="<%= value._id %>"
                    >

                      <option
                        value="ACTIVE"
                        <%= value.memberStatus === 'ACTIVE' ? 'selected' : '' %>
                      >
                        ACTIVE
                      </option>

                      <option
                        value="BLOCK"
                        <%= value.memberStatus === 'BLOCK' ? 'selected' : '' %>
                      >
                        BLOCK
                      </option>

                      <option
                        value="DELETE"
                        <%= value.memberStatus === 'DELETE' ? 'selected' : '' %>
                      >
                        DELETE
                      </option>

                    </select>

                  </td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

      </div>
    </div>

  </div>

  <script type="text/javascript" src="/js/users.js"></script>

</body>

<%- include('includes/footer') %>